    {
      "name": "create user",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "  pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "const body = pm.response.json();\r",
              "\r",
              "pm.test(\"verify the Uesr info\", function () {\r",
              "  pm.expect(body.json).to.be.an(\"object\");\r",
              "  pm.expect(body.json.requestId).to.eql(pm.environment.get(\"requestId\"));\r",
              "  pm.expect(body.json.username).to.eql(pm.environment.get(\"username\"));\r",
              "  pm.expect(body.json.timestamp).to.eql(pm.environment.get(\"timestamp\"));\r",
              "});\r",
              "\r",
              "// Save for next request (demonstrates chaining)\r",
              "pm.environment.set(\"savedUsername\", body.json.username);\r",
              "\r",
              "pm.test(\"Saved username variable set\", function () {\r",
              "  pm.expect(pm.environment.get(\"savedUsername\")).to.eql(body.json.username);\r",
              "});\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const id = Date.now().toString();\r",
              "pm.environment.set(\"requestId\", id);\r",
              "\r",
              "pm.environment.set(\"username\", \"user_\" + id);\r",
              "pm.environment.set(\"timestamp\", new Date().toISOString());\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "",
            "value": "",
            "type": "text",
            "disabled": true
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"requestId\": \"{{requestId}}\",\r\n  \"username\": \"{{username}}\",\r\n  \"timestamp\": \"{{timestamp}}\"\r\n}\r\n",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://{{baseUrl}}/post",
          "protocol": "https",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "post"
          ]
        }
