            "exec": [
              "pm.test(\"Status 200\", () => pm.response.to.have.status(200));\r",
              "\r",
              "const body = pm.response.json();\r",
              "\r",
              "pm.test(\"Checking the parameters is displayed correctly\", () => {\r",
              "    pm.expect(body.args.name).to.eql(\"Anjaly\");\r",
              "    pm.expect(body.args.role).to.eql(\"QA\");\r",
